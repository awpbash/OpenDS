---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { STATUS_LABELS } from "../../lib/content";

const papers = (await getCollection("papers")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);
---

<BaseLayout
  title="Papers | OpenDS"
  description="Accessible deep dives into influential and emerging research, connected to the concepts they rely on."
>
  <main class="gutter container-reading pt-10 pb-14">
    <h1 class="font-sans text-3xl font-semibold tracking-tight">Papers</h1>
    <p class="mt-3 font-serif text-lg leading-relaxed text-ink-muted">
      Deep dives into research that mattered: the problem before the paper, the
      core idea, what the experiments showed, and what changed afterward. Not
      summaries of abstracts, and always connected to the concepts they build
      on.
    </p>

    {
      papers.length === 0 ? (
        <div class="mt-10 border-t border-b border-hairline py-10">
          <p class="font-sans text-sm font-semibold tracking-wide text-ink-muted uppercase">
            Nothing here yet
          </p>
          <p class="mt-3 font-serif leading-relaxed text-ink-muted">
            Attention Is All You Need is the natural opener, since the{" "}
            <a
              href="/concepts/transformers"
              class="text-accent hover:underline"
            >
              Transformers
            </a>{" "}
            page already leans on it. If there is a paper you want to explain,
            claim it: the{" "}
            <a href="/about#join-in" class="text-accent hover:underline">
              contributing guide
            </a>{" "}
            shows how.
          </p>
        </div>
      ) : (
        <ul class="mt-10">
          {papers.map((paper) => (
            <li class="border-t border-hairline py-6 last:border-b">
              <p class="font-sans text-[0.8125rem] tracking-wide text-ink-faint uppercase">
                {STATUS_LABELS[paper.data.status]}
                {paper.data.year && ` · ${paper.data.year}`}
              </p>
              {/* Detail routes arrive with the paper layout (Phase 5). */}
              <p class="mt-1 font-sans text-xl font-semibold tracking-tight">
                {paper.data.title}
              </p>
              <p class="mt-2 font-serif leading-relaxed text-ink-muted">
                {paper.data.description}
              </p>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</BaseLayout>
