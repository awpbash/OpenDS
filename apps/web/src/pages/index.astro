---
import { getCollection } from "astro:content";
import { FAMILY_LABELS } from "@opends/content-schema";
import type { ConceptStatus, Family } from "@opends/content-schema";
import { buildGraph, findNode, START_HERE } from "@opends/graph";
import BaseLayout from "../layouts/BaseLayout.astro";
import FeedCard from "../components/FeedCard.astro";
import KnowledgeGraph from "../components/graph/KnowledgeGraph.tsx";
import { readingMinutes, STATUS_RANK } from "../lib/content";

const [concepts, papers, projects, contributors] = await Promise.all([
  getCollection("concepts"),
  getCollection("papers"),
  getCollection("projects"),
  getCollection("contributors"),
]);

const contributorName = (id: string) =>
  contributors.find((contributor) => contributor.id === id)?.data.name ?? id;

interface FeedItem {
  type: "Concept" | "Paper" | "Project";
  href: string;
  title: string;
  description: string;
  status: ConceptStatus;
  family?: Family;
  minutes: number;
  authors: string;
  cover?: string;
  coverAlt?: string;
  published?: Date;
}

const items: FeedItem[] = [
  ...concepts.map((entry): FeedItem => ({
    type: "Concept",
    href: `/concepts/${entry.data.slug}`,
    title: entry.data.title,
    description: entry.data.description,
    status: entry.data.status,
    family: entry.data.family,
    minutes: readingMinutes(entry.body),
    authors: entry.data.authors.map(contributorName).join(", "),
    cover: entry.data.cover,
    coverAlt: entry.data.coverAlt,
    published: entry.data.published,
  })),
  ...papers.map((entry): FeedItem => ({
    type: "Paper",
    href: `/papers`,
    title: entry.data.title,
    description: entry.data.description,
    status: entry.data.status,
    family: entry.data.family,
    minutes: readingMinutes(entry.body),
    authors: entry.data.authors.map(contributorName).join(", "),
    cover: entry.data.cover,
    published: entry.data.published,
  })),
  ...projects.map((entry): FeedItem => ({
    type: "Project",
    href: `/projects`,
    title: entry.data.title,
    description: entry.data.description,
    status: entry.data.status,
    family: entry.data.family,
    minutes: readingMinutes(entry.body),
    authors: entry.data.authors.map(contributorName).join(", "),
    cover: entry.data.cover,
    published: entry.data.published,
  })),
];

// The feed's editorial logic: peer-reviewed work is the trusted layer on
// top, everything newer sits below it, newest first within each group.
const byRecency = (a: FeedItem, b: FeedItem) =>
  (b.published?.getTime() ?? 0) - (a.published?.getTime() ?? 0) ||
  a.title.localeCompare(b.title);

const reviewed = items
  .filter((item) => STATUS_RANK[item.status] === 0)
  .sort(byRecency);
const fresh = items
  .filter((item) => STATUS_RANK[item.status] !== 0)
  .sort(byRecency);

const groups = [
  { id: "reviewed", label: "Peer-reviewed", items: reviewed },
  { id: "fresh", label: "Fresh, awaiting review", items: fresh },
].filter((group) => group.items.length > 0);

// Knowledge graph data: published concepts merged with the planned skeleton.
const graph = buildGraph(
  concepts.map((entry) => ({
    slug: entry.data.slug,
    title: entry.data.title,
    family: entry.data.family,
    status: entry.data.status,
    prerequisites: entry.data.prerequisites,
    partOf: entry.data.partOf,
  })),
);

const graphNodes = graph.nodes.map(({ slug, title, family, status }) => ({
  slug,
  title,
  family,
  status,
}));

const startHere = START_HERE.map((slug) => findNode(graph, slug)).filter(
  (node) => node !== undefined,
);
---

<BaseLayout
  title="OpenDS | Learning Data Science by teaching it"
  description="A peer-reviewed, open-source knowledge graph for learning Data Science and AI together."
>
  <main class="gutter container-wide grow pb-14">
    <div
      class="lg:grid lg:grid-cols-[minmax(0,1fr)_19rem] lg:gap-x-14 xl:gap-x-20"
    >
      <div class="min-w-0">
        <p class="mt-4 font-sans text-sm text-ink-muted lg:hidden">
          New here? Start with{" "}
          <a href="/concepts/what-is-data" class="text-accent hover:underline"
            >What Is Data?</a
          >{" "}
          or{" "}
          <a href="/map" class="text-accent hover:underline">explore the map</a
          >.
        </p>

        {
          groups.map((group) => (
            <section aria-label={group.label} class="mt-8">
              <h2 class="font-sans text-sm font-semibold tracking-wide text-ink-muted uppercase">
                {group.label}
              </h2>
              <ul class="mt-2">
                {group.items.map((item) => (
                  <FeedCard {...item} />
                ))}
              </ul>
            </section>
          ))
        }
      </div>

      <aside class="hidden lg:block" aria-label="Explore">
        <div class="sticky top-16 space-y-9 pt-8 font-sans text-sm">
          <section aria-label="The map">
            <h2
              class="text-[0.8125rem] font-semibold tracking-wide text-ink-faint uppercase"
            >
              The map
            </h2>
            <div class="mt-3 rounded border border-hairline p-2">
              <KnowledgeGraph
                client:load
                nodes={graphNodes}
                edges={graph.edges.map(({ source, target }) => ({
                  source,
                  target,
                }))}
                variant="mini"
                familyLabels={FAMILY_LABELS}
              />
            </div>
            <a
              href="/map"
              class="mt-3 inline-block font-medium text-accent hover:underline"
            >
              Explore the full map →
            </a>
          </section>

          <section aria-label="Start here">
            <h2
              class="text-[0.8125rem] font-semibold tracking-wide text-ink-faint uppercase"
            >
              Start here
            </h2>
            <ol class="mt-3 space-y-2">
              {
                startHere.map((node, index) => (
                  <li class="flex items-baseline gap-2.5">
                    <span class="text-ink-faint">{index + 1}.</span>
                    {node.status === "planned" ? (
                      <span class="text-ink-faint">{node.title} · soon</span>
                    ) : (
                      <a
                        href={`/concepts/${node.slug}`}
                        class="text-ink-muted hover:text-accent"
                      >
                        {node.title}
                      </a>
                    )}
                  </li>
                ))
              }
            </ol>
          </section>

          <p class="border-t border-hairline pt-5 text-ink-muted">
            Want to write or review?{" "}
            <a href="/about#join-in" class="text-accent hover:underline"
              >See how it works →</a
            >
          </p>
        </div>
      </aside>
    </div>
  </main>
</BaseLayout>
